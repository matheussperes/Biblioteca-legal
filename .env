# PostgreSQL com extensão pgvector.
#
# Desenvolvimento local (Docker): use a mesma URL nos dois campos.
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/knowledge_pipeline?schema=public"
#   DIRECT_URL="postgresql://postgres:postgres@localhost:5432/knowledge_pipeline?schema=public"
#
# Produção (Supabase + Vercel):
#   DATABASE_URL  → URL do pooler (Transaction mode, porta 6543) — usada em runtime pelo Prisma.
#   DIRECT_URL    → URL direta (porta 5432)                      — usada apenas para migrações.
#   Ambas estão disponíveis em: Supabase → Project Settings → Database → Connection string.

# Connect to Postgres via the shared transaction-mode pooler (IPv4-only)
DATABASE_URL="postgresql://postgres.zunrinadqtbpbmpiwsqp:E@&J2025hls0U@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Connect to Postgres via the shared session-mode pooler (used for migrations)
DIRECT_URL="postgresql://postgres.zunrinadqtbpbmpiwsqp:E@&J2025hls0U@aws-1-us-west-2.pooler.supabase.com:5432/postgres"

